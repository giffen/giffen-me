---
import BaseLayout from "../layouts/BaseLayout.astro";
import WritingCard from "../components/WritingCard.astro";
import { getCollection } from "astro:content";

const workPosts = await getCollection("work");
const writingPosts = await getCollection("writing");

const featuredWorkSlugs = [
  "nextgen-platform-migration",
  "pm-insights",
  "ehs-applicability-engine",
];

const featuredWorkMeta: Record<string, { label: string; badge: string }> = {
  "nextgen-platform-migration": { label: "Half the enterprise base migrated", badge: "Shipped" },
  "pm-insights": { label: "74K+ calls, 2.5M sentences in production", badge: "In Use" },
  "ehs-applicability-engine": { label: "500+ screening questions automated", badge: "In Use" },
};

const featuredWork = featuredWorkSlugs
  .map(slug => workPosts.find(p => p.slug === slug))
  .filter((p): p is NonNullable<typeof p> => Boolean(p));

const featuredWritingSlugs = [
  "pm-spectrum",
  "competitive-intelligence-whatsapp",
  "the-pressure-test",
  "ai-features-that-earn-trust",
];

const featuredWritingExcerpts: Record<string, string> = {
  "pm-spectrum": "The Ravi Mehta competency model is the best PM framework ever built. AI just collapsed half the chart. Here's what replaces it - and what it means for how you build and evaluate product teams.",
  "competitive-intelligence-whatsapp": "Research bots were emailing me insights I never read. So I built a system that accumulates and synthesizes knowledge over months, answers questions from WhatsApp, and produces battlecards for the team.",
  "the-pressure-test": "Shipping three to five days of work per evening. The bottleneck isn't context length or typing speed - it's whether you spent ten minutes pressure-testing the plan first.",
  "ai-features-that-earn-trust": "When the stakes involve legal compliance, workplace safety, and regulatory penalties, enterprise customers need more than impressive demos. They need proof your specialized AI won't become a liability.",
};

const featuredWriting = featuredWritingSlugs
  .map(slug => writingPosts.find(p => p.slug === slug))
  .filter((p): p is NonNullable<typeof p> => Boolean(p));
---

<BaseLayout
  title="Andrew Giffen - Product & Technology Executive"
  description="Director of Product at a global compliance SaaS company. I run the largest business unit and personally ship the AI systems inside it."
>

  <!-- Hero Section -->
  <section class="hero">
    <div class="hero-content">
      <p class="hero-label animate-in">Andrew Giffen</p>
      <h1 class="hero-title animate-in delay-1">
        I run a global compliance product.<br>
        And I build the <em>AI</em> that makes it smarter.
      </h1>
      <p class="hero-description animate-in delay-2">
        Director of Product at a global compliance SaaS company. I run the largest
        business unit and personally ship the production AI systems inside it.
        A decade in regulated industries. Toronto.
      </p>
      <div class="hero-cta animate-in delay-3">
        <a href="/work" class="cta-primary">
          View my work
          <svg viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a href="/contact" class="cta-secondary">
          Get in touch
        </a>
      </div>
    </div>
  </section>

  <!-- Featured Work -->
  <section class="featured" id="featured">
    <div class="section-header">
      <div>
        <p class="section-label">Work</p>
        <h2 class="section-title">Selected Projects</h2>
      </div>
    </div>

    <div class="work-list">
      {featuredWork.map((post) => {
        const meta = featuredWorkMeta[post.slug];
        const heroImage = post.data.featuredImage ?? post.data.image;
        const pattern = post.data.pattern ?? 1;
        return (
          <a href={`/work/${post.slug}`} class="work-row">
            <div class={`work-row-media ${heroImage ? 'has-image' : `work-pattern-${pattern}`}`}>
              {heroImage && (
                <img src={heroImage} alt="" class="work-row-image" loading="lazy" />
              )}
            </div>
            <div class="work-row-body">
              <div class="work-row-meta">
                <span class="work-row-label">{meta.label}</span>
                <span class="work-row-badge">{meta.badge}</span>
              </div>
              <h3 class="work-row-title">{post.data.title}</h3>
              <p class="work-row-description">{post.data.description}</p>
              <span class="work-row-cta">
                View project
                <svg viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </span>
            </div>
          </a>
        );
      })}
    </div>

    <div class="section-footer">
      <a href="/work" class="section-footer-link">
        See all work
        <svg viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
  </section>

  <!-- Writing Section -->
  <section class="writing-section" id="writing">
    <div class="section-header">
      <div>
        <p class="section-label">Writing</p>
        <h2 class="section-title">Recent Posts</h2>
      </div>
    </div>

    <div class="writing-grid">
      {featuredWriting.map((post, index) => (
        <WritingCard
          title={post.data.title}
          slug={post.slug}
          tag={post.data.tag}
          excerpt={featuredWritingExcerpts[post.slug] ?? post.data.excerpt}
          number={String(index + 1).padStart(2, '0')}
        />
      ))}
    </div>

    <div class="section-footer">
      <a href="/writing" class="section-footer-link">
        See all writing
        <svg viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
  </section>

</BaseLayout>

<style>
  /* Hero Section */
  .hero {
    position: relative;
    min-height: 90vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-10) var(--space-7) var(--space-9);
    overflow: hidden;
  }

  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: url('/images/hero/hero-bg.webp');
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    opacity: 0.55;
    pointer-events: none;
    z-index: 0;
  }

  :root[data-theme="dark"] .hero::before {
    opacity: 0;
  }

  .hero::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: min(560px, 70%);
    height: 1px;
    background: linear-gradient(
      to right,
      transparent,
      var(--paper-edge) 30%,
      var(--paper-edge) 70%,
      transparent
    );
    pointer-events: none;
  }

  .hero-content {
    position: relative;
    z-index: 1;
    max-width: 720px;
    margin: 0 auto;
    text-align: center;
  }

  .hero-label {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.18em;
    margin-bottom: var(--space-6);
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
  }

  .hero-label::before,
  .hero-label::after {
    content: '';
    width: 32px;
    height: 1px;
    background: var(--accent);
    opacity: 0.6;
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: var(--text-5xl);
    font-weight: 400;
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: var(--ink);
    margin-bottom: var(--space-7);
  }

  .hero-title em {
    font-style: italic;
    color: var(--accent);
  }

  .hero-description {
    font-size: var(--text-lg);
    color: var(--ink-soft);
    max-width: 52ch;
    margin: 0 auto var(--space-8);
    line-height: 1.6;
  }

  .hero-cta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-5);
    flex-wrap: wrap;
  }

  .cta-primary {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-4) var(--space-6);
    background: var(--ink);
    color: var(--cream);
    font-family: var(--font-body);
    font-size: var(--text-sm);
    border-radius: 6px;
    transition: background 0.3s ease, transform 0.3s ease;
  }

  .cta-primary:hover {
    background: var(--accent);
    transform: translateY(-1px);
  }

  .cta-primary svg {
    width: 16px;
    height: 16px;
    stroke: currentColor;
    stroke-width: 2;
    fill: none;
    transition: transform 0.3s ease;
  }

  .cta-primary:hover svg {
    transform: translateX(3px);
  }

  .cta-secondary {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--ink-soft);
    padding: var(--space-3) var(--space-2);
    border-bottom: 1px solid var(--paper-edge);
    transition: color 0.2s ease, border-color 0.2s ease;
  }

  .cta-secondary:hover {
    color: var(--accent);
    border-color: var(--accent);
  }

  /* Featured Section */
  .featured {
    padding: var(--space-10) var(--space-7);
    background: var(--cream-dark);
    position: relative;
  }

  .featured::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: var(--paper-edge);
  }

  .work-list {
    display: flex;
    flex-direction: column;
    margin-top: var(--space-6);
    border-top: 1px solid var(--paper-edge);
  }

  .work-row {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: var(--space-7);
    align-items: center;
    padding: var(--space-7) 0;
    border-bottom: 1px solid var(--paper-edge);
    color: inherit;
    text-decoration: none;
    transition: transform 0.25s ease;
    position: relative;
  }

  .work-row:hover {
    transform: translateX(var(--space-2));
  }

  .work-row-media {
    width: 100%;
    aspect-ratio: 4 / 3;
    border-radius: 8px;
    overflow: hidden;
    position: relative;
    box-shadow:
      0 1px 2px rgba(0, 0, 0, 0.04),
      0 8px 24px rgba(0, 0, 0, 0.06);
  }

  .work-row-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .work-row:hover .work-row-image {
    transform: scale(1.03);
  }

  /* Pattern fallback gradients (when no image yet) */
  .work-pattern-1 { background: linear-gradient(160deg, #1E4B8E 0%, #152F54 100%); }
  .work-pattern-2 { background: linear-gradient(160deg, #8E4B1E 0%, #5C3012 100%); }
  .work-pattern-3 { background: linear-gradient(160deg, #1E8E4B 0%, #125C2F 100%); }
  .work-pattern-4 { background: linear-gradient(160deg, #4B1E8E 0%, #2F125C 100%); }
  .work-pattern-5 { background: linear-gradient(160deg, #8E1E4B 0%, #5C122F 100%); }
  .work-pattern-6 { background: linear-gradient(160deg, #2D4A3E 0%, #1A2D26 100%); }

  .work-row-body {
    min-width: 0;
  }

  .work-row-meta {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    margin-bottom: var(--space-3);
  }

  .work-row-label {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }

  .work-row-badge {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--ink-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 2px 10px;
    border: 1px solid var(--paper-edge);
    border-radius: 4px;
  }

  .work-row-title {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: 500;
    color: var(--ink);
    line-height: 1.25;
    margin-bottom: var(--space-3);
  }

  .work-row-description {
    color: var(--ink-soft);
    font-size: var(--text-base);
    max-width: 70ch;
    margin-bottom: var(--space-4);
    line-height: 1.6;
  }

  .work-row-cta {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--ink-soft);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    transition: color 0.2s ease;
  }

  .work-row:hover .work-row-cta {
    color: var(--accent);
  }

  .work-row-cta svg {
    width: 14px;
    height: 14px;
    stroke: currentColor;
    stroke-width: 2;
    fill: none;
    transition: transform 0.2s ease;
  }

  .work-row:hover .work-row-cta svg {
    transform: translateX(3px);
  }

  /* Section footer link */
  .section-footer {
    margin-top: var(--space-7);
    display: flex;
    justify-content: flex-end;
  }

  .section-footer-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--ink-soft);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    transition: color 0.2s ease, gap 0.2s ease;
  }

  .section-footer-link:hover {
    color: var(--accent);
    gap: var(--space-4);
  }

  .section-footer-link svg {
    width: 18px;
    height: 18px;
    stroke: currentColor;
    stroke-width: 1.5;
    fill: none;
  }

  /* Writing Section */
  .writing-section {
    padding: var(--space-10) var(--space-7);
    background: var(--cream);
    position: relative;
  }

  .writing-section::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: var(--paper-edge);
  }

  .writing-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-7);
    margin-top: var(--space-8);
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .writing-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 1024px) {
    .work-row {
      grid-template-columns: 220px 1fr;
      gap: var(--space-6);
    }
  }

  @media (max-width: 768px) {
    .hero {
      padding: var(--space-9) var(--space-5);
      min-height: 80vh;
    }

    .featured,
    .writing-section {
      padding: var(--space-8) var(--space-5);
    }

    .hero-cta {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-4);
    }

    .work-row {
      grid-template-columns: 1fr;
      gap: var(--space-5);
    }

    .work-row-media {
      aspect-ratio: 16 / 9;
    }

    .work-row-title {
      font-size: var(--text-xl);
    }

    .work-row:hover {
      transform: none;
    }
  }
</style>
