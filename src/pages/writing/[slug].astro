---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("writing");
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
---

<BaseLayout title={`${post.data.title} — Writing`} description={post.data.description}>
  <article class="writing-detail">
    <header class="article-header">
      <a href="/writing" class="back-link">
        <svg viewBox="0 0 24 24"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
        Back to Writing
      </a>
      
      <div class="article-meta">
        <span class="article-tag">{post.data.tag}</span>
        <span class="article-date">{post.data.date}</span>
      </div>
      
      <h1 class="article-title">{post.data.title}</h1>
      <p class="article-description">{post.data.description}</p>
    </header>

    <div class="article-content prose">
      <Content />
    </div>

    <footer class="article-footer">
      <p class="footer-text">
        Thanks for reading. If you found this useful, you might also enjoy exploring 
        my <a href="/lab">lab projects</a> or <a href="/writing">other writing</a>.
      </p>
      <div class="footer-cta">
        <a href="https://linkedin.com/in/giffen" class="footer-link" target="_blank" rel="noopener noreferrer">
          <svg viewBox="0 0 24 24"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
          Connect on LinkedIn
        </a>
        <a href="mailto:andy@giffen.me" class="footer-link">
          <svg viewBox="0 0 24 24"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          Get in touch
        </a>
      </div>
    </footer>
  </article>
</BaseLayout>

<style>
  .writing-detail {
    padding: var(--space-10) var(--space-7);
    max-width: 800px;
    margin: 0 auto;
  }

  .article-header {
    margin-bottom: var(--space-8);
    padding-bottom: var(--space-7);
    border-bottom: 1px solid var(--paper-edge);
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--ink-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: var(--space-6);
    transition: color 0.2s ease;
  }

  .back-link:hover {
    color: var(--accent);
  }

  .back-link svg {
    width: 18px;
    height: 18px;
    stroke: currentColor;
    stroke-width: 2;
    fill: none;
  }

  .article-meta {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    margin-bottom: var(--space-4);
  }

  .article-tag {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--accent);
    background: var(--accent-soft);
    padding: 4px 12px;
    border-radius: 4px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .article-date {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--ink-muted);
  }

  .article-title {
    font-family: var(--font-display);
    font-size: var(--text-4xl);
    font-weight: 400;
    color: var(--ink);
    line-height: 1.2;
    margin-bottom: var(--space-4);
  }

  .article-description {
    font-size: var(--text-lg);
    color: var(--ink-soft);
    line-height: 1.7;
  }

  /* Prose styles for markdown content */
  .prose {
    font-size: var(--text-base);
    line-height: 1.8;
    color: var(--ink-soft);
  }

  .prose :global(h2) {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: 500;
    color: var(--ink);
    margin-top: var(--space-8);
    margin-bottom: var(--space-4);
  }

  .prose :global(h3) {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 500;
    color: var(--ink);
    margin-top: var(--space-6);
    margin-bottom: var(--space-3);
  }

  .prose :global(p) {
    margin-bottom: var(--space-5);
  }

  .prose :global(ul),
  .prose :global(ol) {
    margin-bottom: var(--space-5);
    padding-left: var(--space-6);
  }

  .prose :global(li) {
    margin-bottom: var(--space-2);
  }

  .prose :global(blockquote) {
    border-left: 3px solid var(--accent);
    padding-left: var(--space-5);
    margin: var(--space-6) 0;
    font-style: italic;
    color: var(--ink);
  }

  .prose :global(code) {
    font-family: var(--font-mono);
    font-size: 0.9em;
    background: var(--cream-dark);
    padding: 2px 6px;
    border-radius: 4px;
  }

  .prose :global(pre) {
    background: var(--ink);
    color: var(--cream);
    padding: var(--space-5);
    border-radius: 8px;
    overflow-x: auto;
    margin: var(--space-6) 0;
  }

  .prose :global(pre code) {
    background: none;
    padding: 0;
    color: inherit;
  }

  .prose :global(a) {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .prose :global(a:hover) {
    color: var(--accent-light);
  }

  .prose :global(strong) {
    color: var(--ink);
    font-weight: 600;
  }

  .prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: var(--space-6) 0;
  }

  .prose :global(th),
  .prose :global(td) {
    padding: var(--space-3) var(--space-4);
    border: 1px solid var(--paper-edge);
    text-align: left;
  }

  .prose :global(th) {
    background: var(--cream-dark);
    font-weight: 600;
    color: var(--ink);
  }

  .prose :global(img) {
    width: 100%;
    max-width: 100%;
    height: auto;
    margin: var(--space-6) 0;
  }

  /* Screenshot gallery - horizontal scroll strip */
  .prose :global(.screenshot-gallery) {
    display: flex;
    gap: var(--space-3);
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    padding: var(--space-4) 0;
    margin: var(--space-4) 0;
  }

  .prose :global(.screenshot-gallery img) {
    flex: 0 0 auto;
    width: 160px;
    height: auto;
    margin: 0;
    border-radius: 8px;
    border: 1px solid var(--paper-edge);
    scroll-snap-align: start;
    cursor: pointer;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .prose :global(.screenshot-gallery img:hover) {
    transform: scale(1.03);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.12);
  }

  .prose :global(.screenshot-gallery + em) {
    display: block;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--ink-muted);
    text-align: center;
    margin-top: var(--space-1);
    margin-bottom: var(--space-5);
  }

  /* Hide scrollbar but keep functionality */
  .prose :global(.screenshot-gallery::-webkit-scrollbar) {
    height: 6px;
  }

  .prose :global(.screenshot-gallery::-webkit-scrollbar-track) {
    background: var(--cream-dark);
    border-radius: 3px;
  }

  .prose :global(.screenshot-gallery::-webkit-scrollbar-thumb) {
    background: var(--paper-edge);
    border-radius: 3px;
  }

  /* Lightbox overlay */
  :global(.lightbox-overlay) {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.9);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1000;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.25s ease;
  }

  :global(.lightbox-overlay.active) {
    opacity: 1;
    pointer-events: all;
  }

  :global(.lightbox-overlay img) {
    max-width: 90vw;
    max-height: 85vh;
    object-fit: contain;
    border-radius: 8px;
  }

  :global(.lightbox-close) {
    position: absolute;
    top: 20px;
    right: 24px;
    background: none;
    border: none;
    color: white;
    font-size: 32px;
    cursor: pointer;
    line-height: 1;
    padding: 8px;
    opacity: 0.7;
    transition: opacity 0.2s;
  }

  :global(.lightbox-close:hover) {
    opacity: 1;
  }

  :global(.lightbox-nav) {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: none;
    border: none;
    color: white;
    font-size: 36px;
    cursor: pointer;
    padding: 16px;
    opacity: 0.7;
    transition: opacity 0.2s;
  }

  :global(.lightbox-nav:hover) {
    opacity: 1;
  }

  :global(.lightbox-prev) {
    left: 12px;
  }

  :global(.lightbox-next) {
    right: 12px;
  }

  :global(.lightbox-counter) {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    color: rgba(255, 255, 255, 0.6);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
  }

  @media (max-width: 768px) {
    .prose :global(.screenshot-gallery img) {
      width: 130px;
    }
  }

  .prose :global(figure) {
    margin: var(--space-7) 0;
  }

  .prose :global(figure img) {
    margin: 0;
  }

  .prose :global(figcaption) {
    text-align: center;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--ink-muted);
    margin-top: var(--space-3);
  }

  .prose :global(hr) {
    border: none;
    border-top: 1px solid var(--paper-edge);
    margin: var(--space-8) 0;
  }

  /* Footer */
  .article-footer {
    margin-top: var(--space-9);
    padding-top: var(--space-7);
    border-top: 1px solid var(--paper-edge);
  }

  .footer-text {
    font-size: var(--text-base);
    color: var(--ink-soft);
    margin-bottom: var(--space-5);
  }

  .footer-text a {
    color: var(--accent);
  }

  .footer-cta {
    display: flex;
    gap: var(--space-4);
  }

  .footer-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--ink-soft);
    padding: var(--space-3) var(--space-5);
    border: 1px solid var(--paper-edge);
    border-radius: 6px;
    transition: all 0.2s ease;
  }

  .footer-link:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  .footer-link svg {
    width: 18px;
    height: 18px;
    stroke: currentColor;
    stroke-width: 1.5;
    fill: none;
  }

  @media (max-width: 768px) {
    .writing-detail {
      padding: var(--space-9) var(--space-5);
    }

    .article-title {
      font-size: var(--text-3xl);
    }

    .footer-cta {
      flex-direction: column;
    }
  }
</style>

<div class="lightbox-overlay" id="lightbox">
  <button class="lightbox-close" aria-label="Close">&times;</button>
  <button class="lightbox-nav lightbox-prev" aria-label="Previous">&#8249;</button>
  <img src="" alt="" />
  <button class="lightbox-nav lightbox-next" aria-label="Next">&#8250;</button>
  <div class="lightbox-counter"></div>
</div>

<script>
  const overlay = document.getElementById('lightbox');
  if (overlay) {
    const lbImg = overlay.querySelector('img');
    const counter = overlay.querySelector('.lightbox-counter');
    let images = [];
    let currentIndex = 0;

    function show(index) {
      currentIndex = index;
      lbImg.src = images[index].src;
      lbImg.alt = images[index].alt;
      counter.textContent = `${index + 1} / ${images.length}`;
      overlay.classList.add('active');
    }

    function hide() {
      overlay.classList.remove('active');
    }

    document.querySelectorAll('.screenshot-gallery').forEach(gallery => {
      gallery.querySelectorAll('img').forEach(img => {
        img.addEventListener('click', () => {
          images = Array.from(gallery.querySelectorAll('img'));
          const index = images.indexOf(img);
          show(index);
        });
      });
    });

    overlay.querySelector('.lightbox-close').addEventListener('click', hide);
    overlay.querySelector('.lightbox-prev').addEventListener('click', () => {
      show((currentIndex - 1 + images.length) % images.length);
    });
    overlay.querySelector('.lightbox-next').addEventListener('click', () => {
      show((currentIndex + 1) % images.length);
    });
    overlay.addEventListener('click', (e) => {
      if (e.target === overlay) hide();
    });
    document.addEventListener('keydown', (e) => {
      if (!overlay.classList.contains('active')) return;
      if (e.key === 'Escape') hide();
      if (e.key === 'ArrowLeft') show((currentIndex - 1 + images.length) % images.length);
      if (e.key === 'ArrowRight') show((currentIndex + 1) % images.length);
    });
  }
</script>
